#!/bin/bash
# chezmoi run_once_before: Install required packages
# Runs once on first `chezmoi apply` (re-runs if this script changes)

set -euo pipefail

{{ if eq .chezmoi.os "darwin" -}}

# ── Ensure Homebrew is installed ──────────────────────────────────────────
if ! command -v brew &>/dev/null; then
  echo "▶ Installing Homebrew..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  eval "$(/opt/homebrew/bin/brew shellenv 2>/dev/null || /usr/local/bin/brew shellenv)"
fi

echo "▶ Installing packages via Homebrew..."

brew bundle --file=/dev/stdin <<EOF
# ── Shell prompt & plugins ────────────────────────────────────────────────
brew "powerlevel10k"
brew "zsh-autosuggestions"
brew "zsh-syntax-highlighting"

# ── Modern CLI tools ──────────────────────────────────────────────────────
brew "eza"          # ls replacement
brew "bat"          # cat replacement
brew "zoxide"       # cd replacement (smart autojump)
brew "fzf"          # fuzzy finder
brew "ripgrep"      # grep replacement
brew "fd"           # find replacement

# ── Development ───────────────────────────────────────────────────────────
brew "asdf"         # version manager
EOF

# ── Install bat themes (Catppuccin) ───────────────────────────────────────
if command -v bat &>/dev/null; then
  bat_config_dir="$(bat --config-dir)"
  themes_dir="$bat_config_dir/themes"
  if [[ ! -d "$themes_dir" ]] || [[ -z "$(ls -A "$themes_dir" 2>/dev/null)" ]]; then
    echo "▶ Installing bat Catppuccin themes..."
    mkdir -p "$themes_dir"
    curl -fsSL https://github.com/catppuccin/bat/raw/main/themes/Catppuccin%20Mocha.tmTheme -o "$themes_dir/Catppuccin Mocha.tmTheme"
    bat cache --build
  fi
fi

echo "✓ All packages installed!"

{{ else -}}
echo "⚠ Not macOS — skipping brew installs. Install packages manually."
{{ end -}}
